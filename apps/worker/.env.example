# --- TxLINE (devnet) ---
TXLINE_AUTH_HOST=https://txline-dev.txodds.com
TXLINE_DATA_HOST=https://txline-dev.txodds.com
TXLINE_SOLANA_RPC=https://api.devnet.solana.com
# base58 64-byte secret key for the single app wallet that subscribes/activates (devnet)
TXLINE_WALLET_SECRET=
TXLINE_SERVICE_LEVEL_ID=1
TXLINE_SUBSCRIPTION_WEEKS=4
TXLINE_WORLD_CUP_COMPETITION_ID=72

# --- Database ---
# PGlite persists to ./.data/pglite by default (data survives worker restarts).
# Override the location, or set PGLITE_DATA_DIR=:memory: for ephemeral in-memory mode.
PGLITE_DATA_DIR=
# Set DATABASE_URL to use real Postgres (Supabase) instead of PGlite.
# Requires the pg driver: pnpm --filter @touchline/worker add pg
DATABASE_URL=

# --- AI pundit (OpenRouter, FREE model only) ---
# Board-supplied. Both must be set to go live; either absent = template fallback.
# Never set OPENAI_API_KEY or any other unprovided key here (board directive, SAH-55).
OPENROUTER_API_KEY=
# Must be a ":free" model id, e.g. "meta-llama/llama-3.3-70b-instruct:free".
OPENROUTER_MODEL=

# --- Solana trophy minting (devnet) ---
MINT_AUTHORITY_SECRET=

# --- Auth / security ---
# REQUIRED in production: HS256 secret for session JWTs. Dev uses an insecure fallback + warns.
SESSION_SECRET=
# Dev resolve endpoint (/api/dev/resolve): on in dev, auto-off in production.
# Force with ENABLE_DEV_ROUTES=true / disable with =false. Optionally require X-Dev-Token.
ENABLE_DEV_ROUTES=
DEV_RESOLVE_TOKEN=

# --- Worker / gateway ---
WORKER_PORT=8787
# NODE_ENV=production enforces SESSION_SECRET and disables dev routes by default.
NODE_ENV=
